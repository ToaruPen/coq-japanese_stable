# Claude scheduled-task runtime lock
.claude/scheduled_tasks.lock

# Issue #420 build-time pipeline artifacts (transient: conflict reports, .bak files)
# candidates_pending.json IS committed as the source-of-truth input that produces annals-patterns.ja.json
scripts/_artifacts/annals/*.bak
scripts/_artifacts/annals/*.bak-*
scripts/_artifacts/annals/merge_conflicts.json

# Agent-loop generated prompts and summaries
scripts/_artifacts/agent-loop/

# Local Steam Workshop automation state (raw comments and triage audit data)
.coq-japanese_workshop/state/*
.coq-japanese_workshop/backups/*
.coq-japanese_workshop/exports/*
!.coq-japanese_workshop/README.md
!.coq-japanese_workshop/state/.gitkeep
!.coq-japanese_workshop/backups/.gitkeep
!.coq-japanese_workshop/exports/.gitkeep
