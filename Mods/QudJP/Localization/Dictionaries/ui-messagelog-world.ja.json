        {
            "key": "You can't figure out how to safely reach the stairs from here.",
            "context": "XRL.Core.ActionManager",
            "text": "ここから階段へ安全に辿る経路が見つからない。"
        },
        {
            "key": "You cannot see your target.",
            "context": "XRL.Core.ActionManager",
            "text": "目標が見えない。"
        },
        {
            "key": "You cannot do that on the world map.",
            "context": "XRL.Core.XRLCore",
            "text": "ワールドマップではそれはできない。"
        },
        {
            "key": "You can't do that here.",
            "context": "XRL.Messages.MessageQueue",
            "text": "ここではそれはできない。"
        },
        {
            "key": "You cannot do that here.",
            "context": "XRL.Messages.MessageQueue",
            "text": "ここではそれはできない。"
        },
        {
            "key": "You can't recoil yet.",
            "context": "XRL.Messages.MessageQueue",
            "text": "まだリコイルできない。"
        },
        {
            "key": "You bounce.",
            "context": "XRL.Messages.MessageQueue",
            "text": "跳ね返った。"
        },
        {
            "key": "You do not have any more of that kind of item.",
            "context": "XRL.Messages.MessageQueue",
            "text": "その種類のアイテムはもう持っていない。"
        },
        {
            "key": "You eat the meal. It's tastier than usual.",
            "context": "XRL.Messages.MessageQueue",
            "text": "食事をとった。いつもより美味だ。"
        },
        {
            "key": "You feel sick!",
            "context": "XRL.Messages.MessageQueue",
            "text": "気分が悪くなった！"
        },
        {
            "key": "You feel an uncomfortable pressure across the length of your body.",
            "context": "XRL.Messages.MessageQueue",
            "text": "体の隅々に不快な圧迫感を覚えた。"
        },
        {
            "key": "You may fire missile weapons through the forcefield.",
            "context": "XRL.Messages.MessageQueue",
            "text": "フォースフィールド越しに飛び道具を撃てる。"
        },
        {
            "key": "You don't see any hostiles nearby.",
            "context": "XRL.Core.XRLCore",
            "text": "付近に敵対者はいない。"
        },
        {
            "key": "You are shunted to another location!",
            "context": "XRL.World.Parts.Mutation.Teleportation",
            "text": "別の場所へ弾き飛ばされた！"
        },
        {
            "key": "You are teleported to an exit.",
            "context": "XRL.World.Parts.CatacombsExitTeleporter",
            "text": "出口へ転送された。"
        },
        {
            "key": "You are frenzied by the howl!",
            "context": "XRL.World.Parts.Skill.Snapjaw_Howl",
            "text": "遠吠えに興奮させられた！"
        },
        {
            "key": "You activate the recoiler.",
            "context": "XRL.World.Parts.ITeleporter",
            "text": "リコイラーを起動した。"
        },
        {
            "key": "You begin flying!",
            "context": "XRL.World.Capabilities.Flight",
            "text": "飛行を開始した！"
        },
        {
            "key": "You begin using an additional flight capability.",
            "context": "XRL.World.Capabilities.Flight",
            "text": "追加の飛行手段を使い始めた。"
        },
        {
            "key": "You cease using one of your flight capabilities.",
            "context": "XRL.World.Capabilities.Flight",
            "text": "飛行手段の1つの使用をやめた。"
        },
        {
            "key": "You begin itching for a trigger.",
            "context": "XRL.World.Effects.EmptyTheClips",
            "text": "引き金を求めてうずうずしてきた。"
        },
        {
            "key": "You are sucked through the surface of the sphere!",
            "context": "XRL.World.Parts.WorldTeleporter",
            "text": "球の表面に吸い込まれた！"
        },
        {
            "key": "You feel a sense of holiness here.",
            "context": "XRL.HolyPlaceSystem",
            "text": "この場所には神聖さを感じる。"
        },
        {
            "key": "You aggressively swipe your blade in the air.",
            "context": "XRL.World.Parts.LongBladesCore",
            "text": "刃を空中で荒々しく振り払った。"
        },
        {
            "key": "You fall downward!",
            "context": "XRL.World.Parts.StairsDown",
            "text": "下へと落ちた！"
        },
        {
            "key": "You fall to the ground!",
            "context": "XRL.World.Capabilities.Flight",
            "text": "地面に落下した！"
        },
        {
            "key": "You feel a bit better.",
            "context": "XRL.World.Effects.Generic",
            "text": "少し気分が良くなった。"
        },
        {
            "key": "You feel a small ripple in space and time.",
            "context": "XRL.World.Parts.Mutation.MassMind",
            "text": "時空に小さな波紋を感じた。"
        },
        {
            "key": "You feel a sense of infinite grace flow through your being as you are brought from the brink of death to miraculous health.",
            "context": "XRL.World.Parts.Skill.TenfoldPath_Ket",
            "text": "無限の恩寵が身を満たし、死の淵から奇跡的な回復へと引き戻された。"
        },
        {
            "key": "You feel like you forgot something important.",
            "context": "XRL.World.Parts.Mutation.Amnesia",
            "text": "大事な何かを忘れた気がする。"
        },
        {
            "key": "You feel your bones fracture.",
            "context": "XRL.World.Parts.Mutation.BrittleBones",
            "text": "骨がひび割れるのを感じた。"
        },
        {
            "key": "You feel better.",
            "context": "XRL.World.Effects.Generic",
            "text": "気分が良くなった。"
        },
        {
            "key": "You feel feverish.",
            "context": "XRL.World.Effects.Generic",
            "text": "熱っぽく感じる。"
        },
        {
            "key": "You feel increasingly unstable.",
            "context": "XRL.World.Effects.Generic",
            "text": "ますます不安定になっている。"
        },
        {
            "key": "You feel less feverish.",
            "context": "XRL.World.Effects.Generic",
            "text": "熱っぽさが和らいだ。"
        },
        {
            "key": "You feel stiff as a stone.",
            "context": "XRL.World.Effects.Generic",
            "text": "石のように体がこわばる。"
        },
        {
            "key": "You feel uneasy.",
            "context": "XRL.World.Effects.Generic",
            "text": "不安を感じる。"
        },
        {
            "key": "You hear a shloop and the world around you shifts.",
            "context": "XRL.World.Parts.WorldTeleporter",
            "text": "「しゅぽん」という音とともに周囲の世界が歪んだ。"
        },
        {
            "key": "You hear a shloop and then a hitch. Nothing happens.",
            "context": "XRL.World.Parts.WorldTeleporter",
            "text": "「しゅぽん」と音がしたが、途中で止まり、何も起きない。"
        },
        {
            "key": "You feel the cartilage stretch as your leg bones grind together at the joints.",
            "context": "XRL.World.Effects.Generic",
            "text": "足の骨が軋み、軟骨が伸びるのを感じた。"
        },
        {
            "key": "You do that with ease.",
            "context": "XRL.World.Parts.Combat",
            "text": "難なくやってのけた。"
        },
        {
            "key": "You must be in a long blade stance to use that ability.",
            "context": "XRL.World.Parts.LongBladesCore",
            "text": "ロングブレードの型に入っていないとそのアビリティは使えない。"
        },
        {
            "key": "You lose sight of your mark.",
            "context": "XRL.World.Parts.Skill.Rifle_DrawABead",
            "text": "標的を見失った。"
        },
        {
            "key": "You lurch suddenly!",
            "context": "XRL.World.Parts.Mutation.BlinkingTic",
            "text": "突然ぐらりとよろめいた！"
        },
        {
            "key": "You lurch suddenly!",
