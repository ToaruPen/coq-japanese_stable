      </pregen>
    
      <pregen Name="Dream Tortoise" Genotype="Mutated Human" Tile="Creatures/sw_dream_tortoise.bmp" Foreground="y" Detail="w" Background="k">
        <code></code>
        <description>
        &amp;c&#249;&amp;y 近接戦闘型
