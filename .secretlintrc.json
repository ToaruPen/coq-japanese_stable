{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "Steam user literal",
            "patterns": [
              "/\\bpen4216\\b/"
            ]
          },
          {
            "name": "STEAM_USER concrete assignment",
            "patterns": [
              "/\\bSTEAM_USER\\s*=\\s*(?<steam_user>(?!<redacted>|masked|\\$STEAM_USER|\\.\\.\\.)[A-Za-z0-9_.-]{3,})\\b/"
            ]
          },
          {
            "name": "password assignment",
            "patterns": [
              "/\\b(?:STEAM_PASSWORD|PASSWORD|password|passwd|pwd)\\s*=\\s*(?<password>(?!<redacted>|masked|\\$[A-Za-z_][A-Za-z0-9_]*|\\.\\.\\.)[^\\s`\"']{3,})/i"
            ]
          },
          {
            "name": "steamcmd login password argument",
            "patterns": [
              "/steamcmd\\s+\\+login\\s+(?:\"?\\$STEAM_USER\"?|<user>|\\S+)\\s+(?<steam_password>(?!\\+workshop_build_item|\\+quit|<password>|\\$STEAM_PASSWORD|\\$[A-Za-z_][A-Za-z0-9_]*|\\.\\.\\.)[^\\s`\"']{3,})/i"
            ]
          }
        ]
      }
    }
  ]
}
